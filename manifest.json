{
    "name": "Anti-Script Injection",
    "version": "1.0",
    "manifest_version": 3,
    "description": "A Chrome extension to prevent script injection attacks.",
    "icons": {
        "16": "icons/pic1.png",
        "48": "icons/pic2.png",
        "128": "icons/pic3.png"
    },
    "action": {
        "default_popup": "popup.html",
        "default_icon": {
            "16": "icons/pic1.png",
            "48": "icons/pic2.png",
            "128": "icons/pic3.png"
        }
    },
    "content_scripts": [
        {
            "matches": ["<all_urls>"],
            "js": ["scripts/content.js"],
            "run_at": "document_start"
        }
    ]
}